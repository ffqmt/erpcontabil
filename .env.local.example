# URL do Supabase (Client-side e Server-side)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima pública do Supabase (Client-side e Server-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de acesso administrativo (Service Role) - APENAS para uso no servidor.
# IMPORTANTE: Esta chave concede bypass completo em políticas de RLS e regras de segurança.
# Use apenas localmente e de forma temporária durante o desenvolvimento.
# A autenticação final no ambiente produtivo será provida via sessão integrada ao Francoos.
SUPABASE_SERVICE_ROLE_KEY=

# --- CONTEXTO DE FALLBACK (SÓ PARA SCRIPTS/DEV LOCAL SEM SESSÃO) ---
# Etapa 29B: getCurrentContext() (src/lib/context/current-context.ts) hoje deriva
# identidade/empresa/competência da sessão REAL do Supabase Auth (login em /login) — estes
# valores DEV_* só entram em jogo como último recurso, e mesmo assim só se
# DEV_ALLOW_UNAUTHENTICATED_CONTEXT=true estiver definido abaixo. Isso evita que o fallback
# mascare silenciosamente um bug real de sessão/contexto (achado P1 #2 da auditoria E2E da
# Etapa 29A) — sem a flag, qualquer chamada sem sessão simplesmente falha com erro claro.
# Nunca ative esta flag em produção (o código já bloqueia isso via NODE_ENV, mas não
# dependa só disso — deixe a flag ausente/false por padrão).

# Habilita o fallback DEV_* abaixo quando NÃO há sessão Supabase Auth (uso local pontual,
# ex. script isolado). Deixe ausente ou "false" no dia a dia — com o login real funcionando
# (Etapa 27+), este fallback não deveria ser necessário.
DEV_ALLOW_UNAUTHENTICATED_CONTEXT=false

# UUID do Workspace (Escritório de Contabilidade) — só usado se a flag acima for true.
DEV_WORKSPACE_ID=

# UUID da Empresa (Cliente da Transportadora Modelo Ltda) — só usado se a flag acima for true.
DEV_COMPANY_ID=

# UUID do Perfil/Usuário de Desenvolvimento — só usado se a flag acima for true.
DEV_PROFILE_ID=

# Competência Operacional Ativa de fallback (YYYY-MM-01) — só usada se a flag acima for true.
DEV_COMPETENCE=2025-01-01
